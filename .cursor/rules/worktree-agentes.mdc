description: Configuração de worktrees para Agents Payment Hub
alwaysApply: false

# Worktrees relativos ao diretório raiz do projeto
worktrees:
  - name: agents/doc/AGENT-0.txt, agents/doc/AGENT-1.txt, agents/doc/AGENT-2.txt, agents/doc/AGENT-3.txt, agents/doc/AGENT-4.txt, agents/doc/AGENT-5.txt, agents/doc/AGENT-6.txt, agents/doc/AGENT-7.txt, agents/doc/AGENT-8.txt  
    path: /worktrees/payment-hub-api-docs
    branch: docs/payment-flows

  - name: agents/implementation-plan/AGENT-0.txt
    path: /worktrees/payment-hub-api-implementation-commit-plan
    branch: planning/implementation-commit-plan

  - name: agents/dev/implementation-executor/setup/AGENT-0.txt
    path: /worktrees/payment-hub-api-chore-project-setup
    branch: chore/project-setup

  - name: agents/dev/implementation-executor/modules/AGENT-0.txt, agents/dev/architecture-executor/modules/REVIEW-AGENTE-0.txt
    path: /worktrees/payment-hub-api-feat-modules
    branch: feat/modules  

  - name: agents/dev/implementation-executor/dto/AGENT-0.txt, agents/dev/architecture-executor/dto/REVIEW-AGENTE-0.txt, agents/dev/architecture-executor/dto/ADJUSTMENTS-AGENT-0.txt
    path: /worktrees/payment-hub-api-feat-dto
    branch: feat/dto

  - name: agents/dev/implementation-executor/idempotency/AGENT-0.txt, agents/dev/architecture-executor/idempotency/REVIEW-AGENTE-0.txt, agents/dev/architecture-executor/idempotency/ADJUSTMENTS-AGENT-0.txt
    path: /worktrees/payment-hub-api-feat-idempotency
    branch: feat/modules


notes:
  - Use paths relativos para portabilidade entre máquinas
  - A branch main só deve ser atualizada via PR
  - Cada agente deve operar em seu worktree isolado
  - Commits e Git operations devem ocorrer dentro do worktree correspondente