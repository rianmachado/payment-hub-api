    {
      "name": "Payments",
      "item": [
        {
          "name": "Success",
          "item": [
            {
              "name": "01 - POST /v1/payments",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "{{token}}",
                    "type": "text"
                  },
                  {
                    "key": "Idempotency-Key",
                    "value": "{{idempotencyKey}}",
                    "type": "text"
                  },
                  {
                    "key": "X-Correlation-Id",
                    "value": "{{correlationId}}",
                    "type": "text"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"payer\": { \"externalId\": \"cust-001\" },\n  \"payee\": { \"externalId\": \"merchant-002\" },\n  \"amount\": 150.5,\n  \"currency\": \"BRL\",\n  \"paymentMethod\": { \"type\": \"PIX\", \"pixKey\": \"merchant@example.com\" },\n  \"externalReference\": \"invoice-2024-001\",\n  \"metadata\": { \"channel\": \"web\" }\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/v1/payments",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "payments"
                  ]
                },
                "description": "Cria pagamento. Retorna 201 (criacao) ou 200 (replay idempotente)."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('status deve ser 200 ou 201', function () {",
                      "  pm.expect([200, 201]).to.include(pm.response.code);",
                      "});",
                      "",
                      "pm.test('deve retornar X-Correlation-Id', function () {",
                      "  pm.expect(pm.response.headers.has('X-Correlation-Id')).to.be.true;",
                      "});"
                    ]
                  }
                }
              ],
              "response": []
            },
            {
              "name": "02 - GET /v1/payments/:paymentId",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "{{token}}",
                    "type": "text"
                  },
                  {
                    "key": "X-Correlation-Id",
                    "value": "{{correlationId}}",
                    "type": "text"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/v1/payments/{{paymentId}}?expand={{expand}}",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "payments",
                    "{{paymentId}}"
                  ],
                  "query": [
                    {
                      "key": "expand",
                      "value": "{{expand}}",
                      "description": "Opcional. Ex.: events,history"
                    }
                  ]
                },
                "description": "Consulta pagamento por paymentId."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('status deve ser 200', function () {",
                      "  pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test('deve retornar X-Correlation-Id', function () {",
                      "  pm.expect(pm.response.headers.has('X-Correlation-Id')).to.be.true;",
                      "});"
                    ]
                  }
                }
              ],
              "response": []
            },
            {
              "name": "03 - GET /v1/payments/by-idempotency-key/:idempotencyKey",
