    {
      "name": "Payments",
      "item": [
        {
          "name": "POST /v1/payments",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}",
                "type": "text"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotencyKey}}",
                "type": "text"
              },
              {
                "key": "X-Correlation-Id",
                "value": "{{correlationId}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payer\": { \"externalId\": \"cust-001\" },\n  \"payee\": { \"externalId\": \"merchant-002\" },\n  \"amount\": 150.5,\n  \"currency\": \"BRL\",\n  \"paymentMethod\": { \"type\": \"PIX\", \"pixKey\": \"merchant@example.com\" },\n  \"externalReference\": \"invoice-2024-001\",\n  \"metadata\": { \"channel\": \"web\" }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/payments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "payments"
              ]
            },
            "description": "Cria pagamento. Retorna 201 (criacao) ou 200 (replay idempotente)."
          },
          "response": []
        },
        {
          "name": "GET /v1/payments/:paymentId",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}",
                "type": "text"
              },
              {
                "key": "X-Correlation-Id",
                "value": "{{correlationId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/payments/{{paymentId}}?expand={{expand}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "payments",
                "{{paymentId}}"
              ],
              "query": [
                {
                  "key": "expand",
                  "value": "{{expand}}",
                  "description": "Opcional. Ex.: events,history"
                }
              ]
            },
            "description": "Consulta pagamento por paymentId."
          },
          "response": []
        },
        {
          "name": "GET /v1/payments/by-idempotency-key/:idempotencyKey",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}",
                "type": "text"
              },
              {
                "key": "X-Correlation-Id",
                "value": "{{correlationId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/payments/by-idempotency-key/{{idempotencyKey}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "payments",
                "by-idempotency-key",
                "{{idempotencyKey}}"
              ]
            },
            "description": "Consulta pagamento pela chave de idempotencia."
          },
          "response": []
        }
      ]
    }
  ],
