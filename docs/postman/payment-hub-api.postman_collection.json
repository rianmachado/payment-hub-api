        {
          "name": "Security",
          "item": [
            {
              "name": "01 - POST /v1/payments (401 sem Authorization)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Idempotency-Key",
                    "value": "{{idempotencyKey}}",
                    "type": "text"
                  },
                  {
                    "key": "X-Correlation-Id",
                    "value": "{{correlationId}}",
                    "type": "text"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"payer\": { \"externalId\": \"cust-001\" },\n  \"payee\": { \"externalId\": \"merchant-002\" },\n  \"amount\": 150.5,\n  \"currency\": \"BRL\",\n  \"paymentMethod\": { \"type\": \"PIX\", \"pixKey\": \"merchant@example.com\" },\n  \"externalReference\": \"invoice-2024-001\",\n  \"metadata\": { \"channel\": \"web\" }\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/v1/payments",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "payments"
                  ]
                },
                "description": "Cenario de seguranca: deve retornar 401 com code AUTH_TOKEN_MISSING quando o header Authorization nao for enviado."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('status deve ser 401', function () {",
                      "  pm.response.to.have.status(401);",
                      "});",
                      "",
                      "pm.test('code deve ser AUTH_TOKEN_MISSING', function () {",
                      "  var json = pm.response.json();",
                      "  pm.expect(json.code).to.eql('AUTH_TOKEN_MISSING');",
                      "});",
                      "",
                      "pm.test('deve retornar correlationId no body', function () {",
                      "  var json = pm.response.json();",
                      "  pm.expect(json.correlationId).to.be.a('string').and.not.empty;",
                      "});"
                    ]
                  }
                }
              ],
              "response": []
            },
